<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- LoginServlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.zerodech.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- RegisterServlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.zerodech.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- LogoutServlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.zerodech.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- PickupServlet -->
    <servlet>
        <servlet-name>PickupServlet</servlet-name>
        <servlet-class>com.zerodech.servlet.PickupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PickupServlet</servlet-name>
        <url-pattern>/pickup</url-pattern>
    </servlet-mapping>

    <!-- SubscribeServlet -->
    <servlet>
        <servlet-name>SubscribeServlet</servlet-name>
        <servlet-class>com.zerodech.servlet.SubscribeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubscribeServlet</servlet-name>
        <url-pattern>/subscribe</url-pattern>
    </servlet-mapping>

    <!-- PaymentServlet -->
    <servlet>
        <servlet-name>PaymentServlet</servlet-name>
        <servlet-class>com.zerodech.servlet.PaymentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PaymentServlet</servlet-name>
        <url-pattern>/payment</url-pattern>
    </servlet-mapping>

    <!-- FeedbackServlet -->
    <servlet>
        <servlet-name>FeedbackServlet</servlet-name>
        <servlet-class>com.zerodech.servlet.FeedbackServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FeedbackServlet</servlet-name>
        <url-pattern>/feedback</url-pattern>
    </servlet-mapping>

    <!-- UpdateStatusServlet -->
    <servlet>
        <servlet-name>UpdateStatusServlet</servlet-name>
        <servlet-class>com.zerodech.servlet.UpdateStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateStatusServlet</servlet-name>
        <url-pattern>/update-status</url-pattern>
    </servlet-mapping>

    <!-- AssignCollectorServlet -->
    <servlet>
        <servlet-name>AssignCollectorServlet</servlet-name>
        <servlet-class>com.zerodech.servlet.AssignCollectorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AssignCollectorServlet</servlet-name>
        <url-pattern>/assign-collector</url-pattern>
    </servlet-mapping>

</web-app>